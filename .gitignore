# Build artifacts
/bin/
/dist/
/stage/
/npm/.stage/
/ARCDESK
/ARCDESK.exe

# Website (Astro) build output
/site/dist/
/site/.astro/
/site/_preview.png

# Go test/build scratch
*.test
*.out
*.coverprofile
coverage.out
cpu.prof
mem.prof

# Wails desktop artifacts
/desktop/build/*
!/desktop/build/appicon.png
/desktop/desktop
/desktop/frontend/dist/*
!/desktop/frontend/dist/.gitkeep
/desktop/frontend/wailsjs/
/desktop/frontend/package.json.md5
/desktop/frontend/test-results/
/desktop/frontend/playwright-report/

# Environment / local config (ARCDESK.example.toml is the shared template)
.env
.env.local
*.local
/ARCDESK.toml
/desktop/.env
/desktop/ARCDESK.toml

# Legacy Reasonix skill mirror (use bundled-skills/ instead)
.reasonix/
.pnpm-store/
.npm/

# Project-local ARCDESK state; keep the checked-in review command.
/.ARCDESK/*
!/.ARCDESK/commands/
!/.ARCDESK/commands/review.md

# CodeGraph per-project index (rebuilt locally; never committed)
.codegraph/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# Scratch / agent working dirs (never committed)
/tmp/
/.codex/
/_rename-to-arcdesk.ps1
reasonix.toml.bak*
